# Monitoring Stack Environment Variables
# Copy this file to .env and update with your values

# ===========================================
# Caddy API Key Authentication
# ===========================================
# Generate a secure random key: openssl rand -hex 32
CADDY_API_KEY=your-32-character-secure-api-key-here

# ===========================================
# Grafana Admin Credentials
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-password

# ===========================================
# Prometheus Basic Auth
# ===========================================
# Generate hash: htpasswd -nbBC 12 user password | cut -d: -f2
PROMETHEUS_BASIC_AUTH_USER=prometheus-admin
PROMETHEUS_BASIC_AUTH_HASH=$2y$12$OsbB.kLJTn2ityYL1udRhOFAUWGjSWt9pmmeHn6fd8mD5H.dug12G

# ===========================================
# cAdvisor Basic Auth
# ===========================================
CADVISOR_BASIC_AUTH_USER=cadvisor-admin
CADVISOR_BASIC_AUTH_HASH=$2y$12$brFyWNQo6iIwotWK0J55eOxE3zHJOdzFfiX2jvF.XzjvTRTFPX8fO

# ===========================================
# Backup Configuration
# ===========================================
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPT=false
# BACKUP_GPG_RECIPIENT=your-gpg-key-id
